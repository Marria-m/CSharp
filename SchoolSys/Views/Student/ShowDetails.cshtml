@model SchoolSystem.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<h2>Student Details</h2>

<table border="1" cellpadding="8" cellspacing="0">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>Age</th>
        <td>@Model.Age</td>
    </tr>
    <tr>
        <th>Department</th>
        <td>@Model.Department?.Name</td>
    </tr>
</table>

<h3>Enrolled Courses</h3>

@if (Model.StuCrsRes != null && Model.StuCrsRes.Any())
{
    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr>
                <th>Course</th>
                <th>Degree</th>
                <th>Min Degree</th>
                <th>Grade</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in Model.StuCrsRes)
            {
                <tr>
                    <td>@record.Course?.Name</td>
                    <td>@record.Course?.Degree</td>
                    <td>@record.Course?.MinDegree</td>
                    <td>@record.Grade</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>This student is not enrolled in any courses.</p>
}

<br />
<a href="/Student/ShowAll">Back to All Students</a>
