@model SchoolSystem.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<h1>Delete Student</h1>
<h3>Are you sure you want to delete this student?</h3>

<table class="table table-bordered" style="width:400px;">
    <tr><th>Id</th>         <td>@Model.Id</td></tr>
    <tr><th>Name</th>       <td>@Model.Name</td></tr>
    <tr><th>Age</th>        <td>@Model.Age</td></tr>
    <tr><th>Department</th> <td>@Model.Department?.Name</td></tr>
</table>

@* POST to ConfirmDelete *@
<form method="post" action="/Student/ConfirmDelete">
    <input type="hidden" name="Id" value="@Model.Id" />
    <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    <a href="/Student/Index" class="btn btn-secondary">No, Go Back</a>
</form>
