@model IEnumerable<SchoolSystem.Models.Student>

@{
    ViewData["Title"] = "All Students";
}

<h2>All Students</h2>

<table border="1" cellpadding="8" cellspacing="0">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Age</th>
            <th>Department</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Age</td>
                <td>@student.Department?.Name</td>
                <td>
                    <a href="/Student/ShowDetails?id=@student.Id">View Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
